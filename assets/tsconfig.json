{
  "compilerOptions": {
    "target": "ES6",
    "module": "esnext",
    "moduleResolution": "node",
    "jsx": "react",
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "playwright.config.ts",
  ],
  "exclude": [
    "node_modules",
  ],
}