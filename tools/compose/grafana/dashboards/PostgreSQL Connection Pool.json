          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "expr": "krenalis_db_acquired_conns",
          "legendFormat": "Acquired Connections",
          "refId": "A"
        },
        {
          "expr": "krenalis_db_max_conns",
          "legendFormat": "Max Connections Limit",
          "refId": "B"
        }
      ],
      "title": "Connections In Use vs Max Limit",
      "type": "timeseries"
