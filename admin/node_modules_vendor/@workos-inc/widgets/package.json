{
  "name": "@workos-inc/widgets",
  "version": "1.10.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/esm/index.js",
        "types": "./dist/esm/index.d.ts"
      },
      "require": {
        "default": "./dist/cjs/index.cjs",
        "types": "./dist/cjs/index.d.cts"
      }
    },
    "./*": {
      "import": {
        "default": "./dist/esm/*.client.js",
        "types": "./dist/esm/*.client.d.ts"
      },
      "require": {
        "default": "./dist/cjs/*.client.cjs",
        "types": "./dist/cjs/*.client.d.cts"
      }
    },
    "./*.css": "./dist/css/*.css",
    "./experimental/api/*": {
      "import": {
        "default": "./dist/esm/experimental/api/*.js",
        "types": "./dist/esm/experimental/api/*.ts"
      },
      "require": {
        "default": "./dist/cjs/experimental/api/*.cjs",
        "types": "./dist/cjs/experimental/api/*.cts"
      }
    },
    "./utils": {
      "import": {
        "default": "./dist/esm/utils.js",
        "types": "./dist/esm/utils.d.ts"
      },
      "require": {
        "default": "./dist/cjs/utils.cjs",
        "types": "./dist/cjs/utils.d.cts"
      }
    }
  },
  "sideEffects": false
}