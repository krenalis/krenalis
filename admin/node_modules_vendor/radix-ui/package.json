{
  "name": "radix-ui",
  "version": "1.4.3",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/index.mjs",
        "types": "./dist/index.d.mts"
      },
      "require": {
        "default": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "./*": {
      "import": {
        "default": "./dist/*.mjs",
        "types": "./dist/*.d.mts"
      },
      "require": {
        "default": "./dist/*.js",
        "types": "./dist/*.d.ts"
      }
    }
  },
  "sideEffects": false
}