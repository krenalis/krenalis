{
  "name": "chichi-analytics.js",
  "version": "0.0.1",
  "scripts": {
    "test": "deno test *_test.js",
    "fmt": "deno fmt --use-tabs --single-quote --line-width=120 *.js",
    "prettier-test-website": "npx prettier@latest --write \"./website-for-testing/**/*\"",
    "bundle": "esbuild chichi.js --outfile=build/chichi.bundle.js --bundle",
    "transpile": "swc build/chichi.bundle.js -o build/chichi.es5.js",
    "minify": "esbuild build/chichi.es5.js --outfile=dist/chichi.min.js --minify --format=iife --target=es5",
    "build": "npm run bundle && npm run transpile && npm run minify",
    "build:es6": "esbuild analytics.js --outfile=dist/chichi.es6.min.js --bundle --minify --format=esm --target=es6"
  },
  "devDependencies": {
    "@swc/cli": "0.3.0",
    "@swc/core": "1.3.105",
    "esbuild": "0.20.0",
    "prettier": "3.2.4"
  }
}
